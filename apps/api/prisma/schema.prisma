generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Identidade & acesso
// ------------------------------------------------------------------

model Empresa {
  id           String   @id @default(uuid())
  razaoSocial  String
  nomeFantasia String
  cnpj         String   @unique
  alias        String?  @unique
  logoUrl      String?
  ativo        Boolean  @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  usuarioEmpresas UsuarioEmpresa[]
  perfis          Perfil[]
  clientes        Cliente[]
  notasSaida      NotaSaida[]
  produtos        Produto[]
  titulosReceber  TituloReceber[]

  @@map("empresas")
}

model Usuario {
  id          String    @id @default(uuid())
  nome        String
  email       String    @unique
  senhaHash   String
  ativo       Boolean   @default(true)
  ultimoLogin DateTime?
  avatarUrl   String?
  mfaEnabled  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  usuarioEmpresas UsuarioEmpresa[]
  refreshTokens   RefreshToken[]

  @@map("usuarios")
}

// Vínculo usuário×empresa: perfil (RBAC) + hierarquia/dados de vendedor
// nessa empresa (ver docs/regras-de-negocio.md). Um usuário multiempresa tem
// um registro aqui por empresa, cada um com seu próprio perfil/superior. O
// perfil sistemaBase enxerga tudo da empresa sem restrição de carteira; os
// demais são escopados pela árvore superiorId, qualquer que seja o perfil.
model UsuarioEmpresa {
  id        String  @id @default(uuid())
  usuarioId String
  empresaId String
  perfilId  String
  ativo     Boolean @default(true)

  superiorId     String?
  codigoErp      String?
  nomeReduzido   String?
  telefone       String?
  celular        String?
  dataNascimento DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  usuario   Usuario          @relation(fields: [usuarioId], references: [id])
  empresa   Empresa          @relation(fields: [empresaId], references: [id])
  perfil    Perfil           @relation(fields: [perfilId], references: [id])
  superior  UsuarioEmpresa?  @relation("UsuarioEmpresaHierarquia", fields: [superiorId], references: [id])
  liderados UsuarioEmpresa[] @relation("UsuarioEmpresaHierarquia")

  clientes       Cliente[]
  notasSaida     NotaSaida[]
  titulosReceber TituloReceber[]

  @@unique([usuarioId, empresaId])
  @@map("usuario_empresas")
}

model Perfil {
  id          String  @id @default(uuid())
  empresaId   String
  nome        String
  descricao   String?
  sistemaBase Boolean @default(false)
  ativo       Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  empresa         Empresa           @relation(fields: [empresaId], references: [id])
  usuarioEmpresas UsuarioEmpresa[]
  permissoes      PerfilPermissao[]

  @@unique([empresaId, nome])
  @@map("perfis")
}

model Modulo {
  id     String  @id @default(uuid())
  nome   String
  icone  String?
  ordem  Int     @default(0)
  ativo  Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  menus Menu[]

  @@map("modulos")
}

model Menu {
  id        String  @id @default(uuid())
  moduloId  String
  menuPaiId String?
  nome      String
  icone     String?
  rota      String?
  ordem     Int     @default(0)
  ativo     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  modulo   Modulo   @relation(fields: [moduloId], references: [id])
  menuPai  Menu?    @relation("MenuSubmenu", fields: [menuPaiId], references: [id])
  submenus Menu[]   @relation("MenuSubmenu")
  rotinas  Rotina[]

  @@map("menus")
}

model Rotina {
  id     String  @id @default(uuid())
  menuId String
  nome   String
  codigo String
  ativo  Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  menu       Menu              @relation(fields: [menuId], references: [id])
  permissoes PerfilPermissao[]

  @@unique([codigo])
  @@map("rotinas")
}

enum Acao {
  visualizar
  cadastrar
  editar
  excluir
  importar
  exportar
  aprovar
  cancelar
  bloquear
}

model PerfilPermissao {
  id        String  @id @default(uuid())
  perfilId  String
  rotinaId  String
  acao      Acao
  permitido Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?

  perfil Perfil @relation(fields: [perfilId], references: [id])
  rotina Rotina @relation(fields: [rotinaId], references: [id])

  @@unique([perfilId, rotinaId, acao])
  @@map("perfil_permissoes")
}

model RefreshToken {
  id        String    @id @default(uuid())
  usuarioId String
  empresaId String?
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("refresh_tokens")
}

// ------------------------------------------------------------------
// Organização comercial
// ------------------------------------------------------------------

// Cliente da carteira comercial. Vinculado a um vendedor (colaborador), o que
// permite a visão por hierarquia: vendedor vê a própria carteira, supervisor/
// gerente veem a de toda a equipe abaixo.
model Cliente {
  id            String  @id @default(uuid())
  empresaId     String
  colaboradorId String?
  codigoErp     String?
  razaoSocial   String
  nomeFantasia  String?
  cnpjCpf       String?
  inscricaoEstadual String?
  contato       String?
  email         String?
  telefone      String?
  celular       String?
  endereco      String?
  bairro        String?
  municipio     String?
  uf            String?
  cep           String?
  ativo         Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  empresa        Empresa         @relation(fields: [empresaId], references: [id])
  colaborador    UsuarioEmpresa? @relation(fields: [colaboradorId], references: [id])
  notasSaida     NotaSaida[]
  titulosReceber TituloReceber[]

  @@unique([empresaId, codigoErp])
  @@index([empresaId, colaboradorId])
  @@map("clientes")
}

// Catálogo de produtos, espelhando a tabela `produto` do sistema legado
// (categoria/subcategoria achatadas como texto — o legado usa FK, mas o
// cadastro novo não precisa da tabela auxiliar para as análises comerciais).
model Produto {
  id           String  @id @default(uuid())
  empresaId    String
  codigoErp    String
  descricao    String
  unidade      String?
  categoria    String?
  subCategoria String?
  marca        String?
  codigoBarras String?
  ncm          String?
  qtdEmbalagem Float?
  peso         Float?
  ultimoPreco  Float?
  observacao   String?
  ativo        Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  empresa        Empresa         @relation(fields: [empresaId], references: [id])
  itensNotaSaida NotaSaidaItem[]

  @@unique([empresaId, codigoErp])
  @@index([empresaId, descricao])
  @@map("produtos")
}

// Título a receber (contas a receber), espelhando `titulo_receber` do legado.
// `saldo` > 0 = em aberto; vencido quando além disso vencimento < hoje.
// `dtBaixa` registra a liquidação. Vinculado ao vendedor para a visão por
// hierarquia (mesma regra de notas de saída).
model TituloReceber {
  id            String    @id @default(uuid())
  empresaId     String
  clienteId     String?
  colaboradorId String?
  numero        String
  parcela       String?
  prefixo       String?
  tipo          String?
  emissao       DateTime
  vencimento    DateTime
  valor         Float     @default(0)
  saldo         Float     @default(0)
  dtBaixa       DateTime?
  historico     String?
  ativo         Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  empresa     Empresa         @relation(fields: [empresaId], references: [id])
  cliente     Cliente?        @relation(fields: [clienteId], references: [id])
  colaborador UsuarioEmpresa? @relation(fields: [colaboradorId], references: [id])

  @@index([empresaId, clienteId])
  @@index([empresaId, colaboradorId, vencimento])
  @@map("titulos_receber")
}

// Nota fiscal de saída (venda faturada), espelhando a tabela `nota_saida` do
// sistema legado.
model NotaSaida {
  id            String    @id @default(uuid())
  empresaId     String
  clienteId     String?
  colaboradorId String?
  numero        String
  serie         String?
  especieFiscal String?
  dtEmissao     DateTime
  ano           Int
  mes           Int
  vlrMercadoria Float     @default(0)
  vlrDesconto   Float     @default(0)
  vlrIcms       Float     @default(0)
  vlrIpi        Float     @default(0)
  vlrFrete      Float     @default(0)
  vlrItens      Float     @default(0)
  chaveNfe      String?
  observacao    String?
  comodato      Boolean   @default(false)
  ativo         Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  deletedBy String?

  empresa     Empresa         @relation(fields: [empresaId], references: [id])
  cliente     Cliente?        @relation(fields: [clienteId], references: [id])
  colaborador UsuarioEmpresa? @relation(fields: [colaboradorId], references: [id])
  itens       NotaSaidaItem[]

  @@unique([empresaId, numero, serie])
  @@index([empresaId, colaboradorId, ano, mes])
  @@index([empresaId, clienteId])
  @@map("notas_saida")
}

model NotaSaidaItem {
  id          String  @id @default(uuid())
  notaSaidaId String
  produtoId   String?
  item        Int
  descricao   String
  quantidade  Float   @default(1)
  vlrUnitario Float   @default(0)
  vlrDesconto Float   @default(0)
  vlrTotal    Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notaSaida NotaSaida @relation(fields: [notaSaidaId], references: [id], onDelete: Cascade)
  produto   Produto?  @relation(fields: [produtoId], references: [id])

  @@index([notaSaidaId])
  @@index([produtoId])
  @@map("notas_saida_itens")
}

// ------------------------------------------------------------------
// Sistema
// ------------------------------------------------------------------

model AuditLog {
  id            String   @id @default(uuid())
  entidade      String
  entidadeId    String
  acao          String
  usuarioId     String?
  valorAnterior Json?
  valorNovo     Json?
  ip            String?
  userAgent     String?
  criadoEm      DateTime @default(now())

  @@index([entidade, entidadeId])
  @@map("audit_logs")
}
