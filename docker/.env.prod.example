# Variáveis de ambiente do stack de produção (stack.rcgcba.prod.yml).
# No Portainer: Stacks → rcgcba → Environment variables (não é lido de arquivo,
# só serve de referência pra preencher os campos por lá).
#
# DATABASE_URL/REDIS_URL devem apontar pro host/alias do Postgres e do Redis
# já rodando na VPS (fora deste stack) — troque "postgres"/"redis" abaixo
# pelo nome real do serviço/rede usado por eles.

DATABASE_URL="postgresql://plataforma:SENHA_FORTE_AQUI@postgres:5432/plataforma_comercial?schema=public"
REDIS_URL="redis://redis:6379"

JWT_ACCESS_SECRET="gere-um-segredo-forte-aleatorio-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="gere-um-segredo-forte-aleatorio-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

CORS_ORIGIN="https://rcgcba.bjsoft.com.br"
