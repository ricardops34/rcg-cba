# Variáveis de ambiente do stack de produção (stack.rcgcba.prod.yml).
# No Portainer: Stacks → rcgcba → Environment variables (não é lido de arquivo,
# só serve de referência pra preencher os campos por lá).
#
# DATABASE_URL/REDIS_URL devem apontar pro host/alias do Postgres e do Redis
# já rodando na VPS (fora deste stack) — troque "postgres"/"redis" abaixo
# pelo nome real do serviço/rede usado por eles.
#
# DATABASE_URL aqui é o role de APLICAÇÃO ("plataforma_app"), sem BYPASSRLS
# nem superuser — só assim o RLS por empresa (ver
# apps/api/prisma/migrations/README.md) realmente isola os tenants; um role
# dono de tabela ou superusuário ignora as policies. O role "plataforma_app"
# é criado pela migration 20260715221500_app_role_least_privilege com uma
# senha de placeholder ("plataforma_app_dev_only") — troque IMEDIATAMENTE
# após o primeiro `prisma migrate deploy` em produção com:
#   ALTER ROLE plataforma_app WITH PASSWORD 'SENHA_FORTE_AQUI';
# Migrations continuam rodando à parte, com o role dono das tabelas
# ("plataforma"), que não entra nesta variável.

DATABASE_URL="postgresql://plataforma_app:SENHA_FORTE_AQUI@postgres:5432/plataforma_comercial?schema=public"
REDIS_URL="redis://redis:6379"

JWT_ACCESS_SECRET="gere-um-segredo-forte-aleatorio-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="gere-um-segredo-forte-aleatorio-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

CORS_ORIGIN="https://rcgcba.bjsoft.com.br"
