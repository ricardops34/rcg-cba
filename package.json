{
  "name": "plataforma-comercial",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prisma:generate": "pnpm --filter @plataforma/api prisma:generate",
    "prisma:migrate": "pnpm --filter @plataforma/api prisma:migrate",
    "prisma:seed": "pnpm --filter @plataforma/api prisma:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
